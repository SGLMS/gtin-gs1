{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "sglms/gs1-gtin",
    "type": "library",
    "description": "Classes to create or validate GTIN (Global Trade Item Number) and GS1; includes barcode generation. Laravel 12 Service Provider.",
    "keywords": [
        "sglms",
        "gs1",
        "gtin",
        "laravel"
    ],
    "homepage": "https://sglms.com",
    "license": "MIT",
    "authors": [
        {
            "name": "James",
            "email": "james@sglms.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "picqer/php-barcode-generator": "^3.2"
    },
    "require-dev": {
        "laravel/framework": "^12.0",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.27",
        "phpunit/phpunit": "^12"
    },
    "autoload": {
        "psr-4": {
            "Sglms\\Gs1Gtin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "pint": "pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sglms\\Gs1Gtin\\Gs1ServiceProvider"
            ],
            "aliases": {
                "Gtin": "Sglms\\Gs1Gtin\\Facades\\Gtin",
                "Gs1": "Sglms\\Gs1Gtin\\Facades\\Gs1"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
